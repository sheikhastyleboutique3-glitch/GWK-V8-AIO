# ── Root environment template for Docker Compose ──
# Copy to .env and fill in real values:  cp .env.example .env

POSTGRES_USER=gwk_user
POSTGRES_PASSWORD=gwk_password
POSTGRES_DB=gwk_v8_aio

# Generate strong secrets:  openssl rand -hex 32
JWT_SECRET=change_me_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

NODE_ENV=production

# Exact origin used in the browser. No trailing slash. Comma-separated for multiple.
ALLOWED_ORIGINS=http://72.62.36.204
