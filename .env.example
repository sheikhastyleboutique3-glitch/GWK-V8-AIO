# ═══════════════════════════════════════════════════════════════════════════════
# GWK V8 AIO — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# SETUP:
#   1. Copy this file:     cp .env.example .env
#   2. Generate secrets:   openssl rand -hex 32  (run twice, one for each)
#   3. Edit DATABASE_URL, JWT secrets, and ALLOWED_ORIGINS
#   4. Start:              docker compose up -d
#
# SECURITY CHECKLIST (before going live):
#   [ ] JWT_SECRET is a random 64+ character hex string
#   [ ] JWT_REFRESH_SECRET is DIFFERENT from JWT_SECRET
#   [ ] POSTGRES_PASSWORD is strong and unique
#   [ ] ALLOWED_ORIGINS contains only your actual domain(s)
#   [ ] NODE_ENV=production
#   [ ] SMTP credentials configured for email reports
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=gwk_user
POSTGRES_PASSWORD=gwk_password
POSTGRES_DB=gwk_v8_aio

# Full connection string (Docker: use 'postgres' as host; local: use 'localhost')
# connection_limit controls Prisma connection pool size (default 10, use 20 for 5+ branches)
DATABASE_URL=postgresql://gwk_user:gwk_password@postgres:5432/gwk_v8_aio?connection_limit=20

# ── Authentication (REQUIRED in production) ───────────────────────────────────
# CRITICAL: The app WILL NOT START in production without valid secrets.
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=change_me_different_from_jwt_secret

# Token lifetimes (access = short for security, refresh = long for UX)
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# CORS: exact browser origin(s) that can call the API.
# No trailing slash. Comma-separated for multiple origins.
# In development, localhost is always permitted regardless of this setting.
ALLOWED_ORIGINS=https://yourdomain.com

# ── Email (SMTP) — notifications, EOD reports, password resets ────────────────
# Gmail: use App Passwords (https://myaccount.google.com/apppasswords)
# Recommended: Resend, Postmark, or AWS SES for production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ── WhatsApp Business API (Meta) — order status notifications ─────────────────
# Can also be configured in the app UI: Notifications → API Configuration
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# ── Scheduled Reports ─────────────────────────────────────────────────────────
# EOD: sends at 23:55 daily with sales summary
EOD_EMAIL_ENABLED=true
EOD_EMAIL_RECIPIENTS=manager@yourdomain.com

# Weekly: sends Monday at 7:00 AM with 7-day summary + best sellers + staff performance
WEEKLY_REPORT_ENABLED=true
WEEKLY_REPORT_RECIPIENTS=owner@yourdomain.com

# Monthly: sends 1st of month at 7:00 AM with prior month summary
MONTHLY_REPORT_ENABLED=true
MONTHLY_REPORT_RECIPIENTS=owner@yourdomain.com

# ── Print Agent (set on the restaurant's local machine, not the VPS) ──────────
# These are used by agent/print-agent.mjs running ON-PREM at the restaurant.
# API_URL=http://your-vps-ip:3000
# API_EMAIL=admin@gwk.com
# API_PASSWORD=Admin@1234
# BRANCH_ID=2
# POLL_MS=30000

# ── ZATCA (Saudi Arabia e-invoicing — for Saudi expansion) ────────────────────
# Required for ZATCA Phase 2 QR code generation on invoices.
# Set these in the app's Settings page, or here for auto-configuration:
# ZATCA_SELLER_NAME=Your Business Name
# ZATCA_VAT_NUMBER=300000000000003
