# ═══════════════════════════════════════════════════════════════════════════════
# GWK V8 AIO — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env:  cp .env.example .env
# Generate secrets:  openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=gwk_user
POSTGRES_PASSWORD=gwk_password
POSTGRES_DB=gwk_v8_aio

# ── Authentication (REQUIRED in production) ───────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Exact browser origin(s). No trailing slash. Comma-separated for multiple.
ALLOWED_ORIGINS=https://yourdomain.com

# ── Email (SMTP) — for notifications, EOD reports, password resets ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ── WhatsApp Business API (Meta) — for order status notifications ─────────────
# Configure these in the app UI (Notifications → API Configuration) instead,
# or set here for auto-configuration:
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# ── Scheduled Reports ─────────────────────────────────────────────────────────
EOD_EMAIL_ENABLED=true
EOD_EMAIL_RECIPIENTS=manager@yourdomain.com
WEEKLY_REPORT_ENABLED=true
WEEKLY_REPORT_RECIPIENTS=owner@yourdomain.com
MONTHLY_REPORT_ENABLED=true
MONTHLY_REPORT_RECIPIENTS=owner@yourdomain.com
