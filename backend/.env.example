# ═══════════════════════════════════════════════════════════════════════════════
# GWK V8 AIO — Backend Environment
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# For Docker: use "db" as host. For local: use "localhost".
DATABASE_URL="postgresql://gwk_user:gwk_password@localhost:5432/gwk_v8_aio?schema=public"

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED in production (app will crash without these).
# Generate with: openssl rand -hex 32
JWT_SECRET="change_this_in_production_min_32_chars"
JWT_REFRESH_SECRET="change_this_refresh_secret_min_32"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:5173"

# ── Email (SMTP) — notifications + scheduled reports ──────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# ── Scheduled Reports ─────────────────────────────────────────────────────────
# EOD_EMAIL_ENABLED=true
# EOD_EMAIL_RECIPIENTS=manager@gwk.com,owner@gwk.com
# WEEKLY_REPORT_ENABLED=true
# WEEKLY_REPORT_RECIPIENTS=owner@gwk.com
# MONTHLY_REPORT_ENABLED=true
# MONTHLY_REPORT_RECIPIENTS=owner@gwk.com
