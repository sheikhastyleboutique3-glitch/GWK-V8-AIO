# Backend environment — copy to ".env" for local (non-Docker) development.
# Prisma reads DATABASE_URL from here automatically.

# Point at your local Postgres (the docker-compose defaults are erp_user / erp_password / gwk_v7).
# For fresh installs, use gwk_v8_aio as the DB name:
DATABASE_URL="postgresql://gwk_user:gwk_password@localhost:5432/gwk_v8_aio?schema=public"

# Auth — generate with: openssl rand -hex 32
JWT_SECRET="change_this_in_production_min_32_chars"
JWT_REFRESH_SECRET="change_this_refresh_secret_min_32"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Runtime
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:5173"
